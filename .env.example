# ============================================================
# MOLDURIZE WEB — Variáveis de Ambiente
# Copie para .env.local (frontend) e apps/api/.env (backend)
# ============================================================

# --- Clerk (Auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/moldurize

# --- Stripe (Pagamentos) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Planos Stripe (criar no dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- Backend API URL ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Redis (Celery workers) ---
REDIS_URL=redis://localhost:6379

# --- Cloudflare R2 (Storage DXF/G-Code) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=moldurize-files
