# ════════════════════════════════════════════════════════════════════════════
# MOLDURIZE WEB — Root .env.example
# Copy this file to appropriate locations based on deployment target:
#   - Development: Use docker-compose.yml which references per-app .env files
#   - Railway (API): Set these vars in Railway dashboard
#   - Vercel (Frontend): Set these vars in Vercel dashboard
# ════════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════════════════
# BACKEND (FastAPI / apps/api)
# ════════════════════════════════════════════════════════════════════════════

# --- Environment & Logging ---
ENVIRONMENT=production                # development | staging | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
MVP_DEV_MODE=false                     # false for real Clerk login; true only for local dev

# --- CORS Configuration ---
CORS_ORIGINS=                          # Comma-separated list of allowed origins (optional)
CORS_ORIGIN_REGEX=^https://(.+\.)?(moldurize\.com\.br|vercel\.app)$  # Regex pattern for allowed CORS origins

# --- PostgreSQL Database ---
DATABASE_URL=postgresql://moldurize:moldurize_dev@localhost:5432/moldurize
# On Railway: Use the Postgres add-on connection string provided automatically

# --- Redis (Celery workers) ---
REDIS_URL=redis://localhost:6379
# On Railway: Use the Redis add-on connection string provided automatically

# --- Clerk Authentication ---
# Get from: https://dashboard.clerk.com → Webhooks → endpoint signing secret
CLERK_ISSUER_URL=https://<your-clerk-instance>.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_SUBSTITUA_AQUI

# --- Stripe Billing (optional - out of MVP scope) ---
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_SUBSTITUA_AQUI
# Get from: https://dashboard.stripe.com → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUA_AQUI
# Price IDs from: https://dashboard.stripe.com → Products
STRIPE_PRICE_STARTER=price_SUBSTITUA_AQUI
STRIPE_PRICE_PRO=price_SUBSTITUA_AQUI
STRIPE_PRICE_ENTERPRISE=price_SUBSTITUA_AQUI

# --- Cloudflare R2 / S3 Storage (DXF uploads, G-Code archive) ---
# Used for storing uploaded DXF files and generated G-Code outputs
# Get from: https://dash.cloudflare.com → R2 → API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=moldurize-files
R2_ENDPOINT=

# --- Error Tracking (Sentry - optional) ---
# Get from: https://sentry.io → Project settings
SENTRY_DSN=

# ════════════════════════════════════════════════════════════════════════════
# FRONTEND (Next.js / apps/web)
# ════════════════════════════════════════════════════════════════════════════

# --- Clerk Authentication (Public) ---
# Get from: https://dashboard.clerk.com → API Keys → Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_SUBSTITUA_AQUI
# Get from: https://dashboard.clerk.com → API Keys → Secret key
CLERK_SECRET_KEY=sk_test_SUBSTITUA_AQUI

# --- Clerk Sign-in/Sign-up Routes ---
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Backend API URL ---
# For local dev: http://localhost:8001
# For production: https://api.moldurize.com.br or your Railway API domain
NEXT_PUBLIC_API_URL=http://localhost:8001

# --- Stripe Public Key (optional - out of MVP scope) ---
# Get from: https://dashboard.stripe.com → Developers → API keys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_SUBSTITUA_AQUI
