# ════════════════════════════════════════════════════════════════════════════
# MOLDURIZE API — .env.example
# Copy this file to `.env` and fill in the values.
# ════════════════════════════════════════════════════════════════════════════

# --- Environment ---
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# --- CORS ---
# Comma-separated allowed origins (production). Dev defaults to localhost.
CORS_ORIGINS=
CORS_ORIGIN_REGEX=^https://(.+\.)?(moldurize\.com\.br|vercel\.app)$

# --- Database (PostgreSQL) ---
# Leave empty to run in dev mode without DB persistence.
DATABASE_URL=postgresql://moldurize:moldurize_dev@localhost:5432/moldurize

# --- Redis (Celery workers — Pro/Enterprise plan) ---
REDIS_URL=redis://localhost:6379

# --- Clerk (Auth webhook) ---
# Dashboard → Webhooks → endpoint signing secret
CLERK_WEBHOOK_SECRET=whsec_SUBSTITUA_AQUI

# --- Stripe (Billing) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_SUBSTITUA_AQUI
# Dashboard → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUA_AQUI
# Price IDs from Dashboard → Products (one per plan)
STRIPE_PRICE_STARTER=price_SUBSTITUA_AQUI
STRIPE_PRICE_PRO=price_SUBSTITUA_AQUI
STRIPE_PRICE_ENTERPRISE=price_SUBSTITUA_AQUI

# --- Cloudflare R2 / S3 Storage (DXF uploads, G-Code archive) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=moldurize-files
R2_ENDPOINT=

# --- Sentry (Error tracking — optional) ---
SENTRY_DSN=
